<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Horizon Voice — Monochrome Beat</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&display=swap" rel="stylesheet">
    
    <style>
        /* Snap-Beat Animation Logic */
        @keyframes box-beat {
            0%, 15% { 
                transform: scaleY(0.1); 
                opacity: 0.15; 
            }
            45% { 
                transform: scaleY(1); 
                opacity: 0.9; 
            }
            55% { 
                transform: scaleY(0.5); 
                opacity: 0.5; 
            }
            85%, 100% { 
                transform: scaleY(0.1); 
                opacity: 0.15; 
            }
        }

        /* Box-type Bar Style */
        .beat-bar {
            width: 6px; 
            height: 22px;
            background-color: #ffffff; /* Strictly White */
            border-radius: 0px; /* Sharp Box Type */
            transform: scaleY(0.1);
            transform-origin: center;
        }

        /* Active State */
        .is-listening .beat-bar {
            animation: box-beat var(--d) infinite cubic-bezier(.2, .9, .3, 1);
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #000;
            user-select: none;
            -webkit-tap-highlight-color: transparent;
        }

        /* Hairline Border Utility */
        .border-hairline {
            border-width: 0.5px !important;
        }

        /* Fixed Toolbar Height */
        .toolbar-height {
            height: 52px;
            height: calc(52px + env(safe-area-inset-bottom));
        }
    </style>
</head>
<body class="h-screen flex flex-col justify-end overflow-hidden">

    <!-- Single Line Monochrome Toolbar -->
    <div id="voiceBar" 
         class="toolbar-height w-full bg-[#121212] flex items-center px-4 gap-3 border-t border-white/10 relative pb-[env(safe-area-inset-bottom)] transition-none">
        
        <!-- MICRO Language Button (Gray/White) -->
        <button id="langBtn" 
                onclick="toggleLang()"
                class="flex-shrink-0 h-6 px-3 rounded-full border-hairline border-white/20 bg-transparent text-[8px] font-bold uppercase tracking-tighter text-white/40 active:scale-95 transition-all">
            English
        </button>

        <!-- CENTER: Box Beat Visualizer -->
        <div id="beatContainer" class="flex-1 flex items-center justify-center gap-[4px] h-8 overflow-hidden">
            <!-- Box bars generated by JS -->
        </div>

        <!-- MICRO Action Button (Gray/White) -->
        <button id="actionBtn" 
                onclick="toggleAction()"
                class="flex-shrink-0 h-6 min-w-[65px] px-2 rounded-full border-hairline border-white/40 bg-transparent text-[8px] font-black uppercase tracking-widest text-white active:scale-95 transition-all">
            Start
        </button>

    </div>

    <script>
        /**
         * Horizon Keyboard - Monochrome Box Beat
         * Palette: Gray (#121212), White (#FFFFFF)
         * Design: Micro buttons, Box animation, Thin borders.
         */

        let isListening = false;
        let currentLang = 'en';

        const voiceBar = document.getElementById('voiceBar');
        const actionBtn = document.getElementById('actionBtn');
        const langBtn = document.getElementById('langBtn');
        const container = document.getElementById('beatContainer');

        /**
         * Creates the box-type beat bars (strictly white)
         */
        function createBeatBoxes() {
            container.innerHTML = '';
            const totalBars = 20; 

            for (let i = 0; i < totalBars; i++) {
                const bar = document.createElement('div');
                bar.className = 'beat-bar';
                
                // Varied beat durations for rhythmic complexity
                const duration = 0.35 + Math.random() * 0.45;
                const delay = Math.random() * 0.5;
                
                bar.style.setProperty('--d', `${duration}s`);
                bar.style.animationDelay = `${delay}s`;
                
                container.appendChild(bar);
            }
        }

        /**
         * Toggle Voice State
         * No background color change allowed.
         */
        function toggleAction() {
            isListening = !isListening;

            if (isListening) {
                // START LISTENING
                voiceBar.classList.add('is-listening');
                actionBtn.textContent = 'Stop';
                // Maintain same visual weight, only change text
                actionBtn.style.borderColor = 'rgba(255, 255, 255, 0.8)';
            } else {
                // STOP LISTENING
                voiceBar.classList.remove('is-listening');
                actionBtn.textContent = 'Start';
                actionBtn.style.borderColor = 'rgba(255, 255, 255, 0.4)';
            }
        }

        /**
         * Language Toggle
         */
        function toggleLang() {
            currentLang = (currentLang === 'en') ? 'bn' : 'en';
            langBtn.textContent = (currentLang === 'en') ? 'English' : 'Bangla';
        }

        // Initialize Module
        window.addEventListener('DOMContentLoaded', () => {
            createBeatBoxes();
            
            // Clean resize handling
            let timer;
            window.addEventListener('resize', () => {
                clearTimeout(timer);
                timer = setTimeout(createBeatBoxes, 200);
            });
        });

    </script>
</body>
</html>
